# ============================================================
# ResuMate Pro - Backend environment configuration
# Copy this file to ".env" and fill in values.
# Everything has a sensible default so the app runs with ZERO
# config (free local AI models + SQLite) out of the box.
# ============================================================

# ---- App ----
APP_NAME=ResuMate Pro
ENVIRONMENT=development
# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:3000

# ---- Security ----
# Generate a strong secret in production:  openssl rand -hex 32
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Database ----
# Leave blank to use a local SQLite file (great for quick start / dev).
# For production (docker-compose) this is set to Postgres automatically:
#   postgresql+psycopg2://resumate:resumate@db:5432/resumate
DATABASE_URL=

# ---- AI Provider ----
# Options: "local"  -> free, runs offline (sentence-transformers embeddings + heuristic generation)
#          "openai" -> uses OpenAI for parsing/generation (requires OPENAI_API_KEY)
AI_PROVIDER=local

# Only needed if AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Embedding model used by the local provider (downloaded once, then cached)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Embedding backend: auto | neural | lite
#   auto   -> neural if sentence-transformers is installed, else lite
#   neural -> sentence-transformers (needs torch; best quality)
#   lite   -> torch-free hashing embedding (tiny memory, for free hosting)
EMBEDDING_BACKEND=auto
